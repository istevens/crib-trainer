{
    "name": "cribtrainer",
    "type": "module",
    "version": "0.0.1",
    "description": "Game to practice scoring cribbage hands.",
    "scripts": {
        "build": "parcel build index.html",
        "test": "jest --testPathIgnorePatterns tests/",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:all": "npm test && npm run test:e2e",
        "start": "parcel index.html -p 8080",
        "chrome:launch": "/Applications/Google\\ Chrome.app/Contents/MacOS/Google\\ Chrome --remote-debugging-port=9222 --user-data-dir=/tmp/lighthouse_debug --headless=new",
        "lighthouse:run": "lighthouse http://127.0.0.1:8080 --port=9222",
        "audit": "npm run chrome:launch & start-server-and-test start http://127.0.0.1:8080 lighthouse:run && killall 'Google Chrome'"
    },
    "author": "Ian Stevens",
    "license": "ISC",
    "devDependencies": {
        "@parcel/packager-raw-url": "^2.16.4",
        "@parcel/transformer-webmanifest": "^2.13.2",
        "construct-style-sheets-polyfill": "^3.1.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "jsdom": "^16.4.0",
        "parcel": "^2.16.4",
        "start-server-and-test": "^2.1.3",
        "svgo": "^3.3.2"
    },
    "jest": {
        "setupFiles": [
            "construct-style-sheets-polyfill"
        ],
        "moduleNameMapper": {
            "^/(.*)$": "<rootDir>/$1"
        }
    },
    "dependencies": {
        "@playwright/test": "^1.40.0"
    }
}
